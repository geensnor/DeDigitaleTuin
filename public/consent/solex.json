{
  "$schema": "https://raw.githubusercontent.com/cavi-au/Consent-O-Matic/master/rules.schema.json",
  "solex": {
    "detectors": [
      {
        "presentMatcher": [
          {
            "type": "css",
            "target": {
              "selector": "#solex-cbc"
            }
          }
        ],
        "showingMatcher": [
          {
            "type": "css",
            "target": {
              "selector": "#solex-cbc"
            }
          }
        ]
      }
    ],
    "methods": [
      {
        "action": {
          "type": "consent",
          "consents": [
            {
              "matcher": {
                "type": "checkbox",
                "target": {
                  "selector": "#ad_user_data"
                }
              },
              "toggleAction": {
                "type": "click",
                "target": {
                  "selector": "#ad_user_data"
                }
              },
              "type": "B"
            },
            {
              "matcher": {
                "type": "checkbox",
                "target": {
                  "selector": "#ad_personalization"
                }
              },
              "toggleAction": {
                "type": "click",
                "target": {
                  "selector": "#ad_personalization"
                }
              },
              "type": "F"
            },
            {
              "matcher": {
                "type": "checkbox",
                "target": {
                  "selector": "#ad_storage"
                }
              },
              "toggleAction": {
                "type": "click",
                "target": {
                  "selector": "#ad_storage"
                }
              },
              "type": "B"
            },
            {
              "matcher": {
                "type": "checkbox",
                "target": {
                  "selector": "#analytics_storage"
                }
              },
              "toggleAction": {
                "type": "click",
                "target": {
                  "selector": "#analytics_storage"
                }
              },
              "type": "B"
            }
          ]
        },
        "name": "DO_CONSENT"
      },
      {
        "action": {
          "type": "click",
          "target": {
            "selector": "#cb-accept-selected"
          }
        },
        "name": "SAVE_CONSENT"
      },
      {
        "action": {
          "type": "click",
          "target": {
            "selector": "#cb-accept"
          }
        },
        "name": "ACCEPT_ALL"
      },
      {
        "action": {
          "type": "click",
          "target": {
            "selector": "#cb-decline"
          }
        },
        "name": "REJECT_ALL"
      },
      {
        "name": "UTILITY"
      },
      {
        "name": "HIDE_CMP"
      },
      {
        "name": "OPEN_OPTIONS"
      }
    ]
  }
}
